+sub _xml_tag_end {
+    my $textref = shift;
+    my $lt      = shift;
+    my $len     = length($$textref);
+    my $quote;
+    my $pos = $lt + 1;
+    while ( $pos < $len ) {
+        my $char = substr( $$textref, $pos, 1 );
+        if ($quote) {
+            $quote = undef if $char eq $quote;
+        }
+        elsif ( $char eq '"' || $char eq "'" ) {
+            $quote = $char;
+        }
+        elsif ( $char eq '>' ) {
+            return $pos;
+        }
+        $pos++;
+    }
+    return -1;
+}
+
+sub _tree_has_utf8_flag {
+    my $value = shift;
+    if ( ref $value ) {
+        if ( UNIVERSAL::isa( $value, 'HASH' ) ) {
+            foreach my $key ( keys %$value ) {
+                return 1 if utf8::is_utf8($key);
+                return 1 if &_tree_has_utf8_flag( $value->{$key} );
+            }
+        }
+        elsif ( UNIVERSAL::isa( $value, 'ARRAY' ) ) {
+            foreach my $item (@$value) {
+                return 1 if &_tree_has_utf8_flag($item);
+            }
+        }
+        elsif ( UNIVERSAL::isa( $value, 'SCALAR' ) ) {
+            return utf8::is_utf8($$value);
+        }
+        return;
+    }
+    return utf8::is_utf8($value);
+}
