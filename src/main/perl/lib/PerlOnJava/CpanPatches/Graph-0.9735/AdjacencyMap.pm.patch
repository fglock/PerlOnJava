+sub _dumper_quote {
+    my ($value) = @_;
+    $value =~ s/([\\\'])/\\$1/g;
+    return "'$value'";
+}
+
+sub _dumper_hash {
+    my ($hash) = @_;
+    return '{' . join(',', map {
+	my $key = $_;
+	_dumper_quote($key) . ' => ' . _dumper_value($hash->{$key});
+    } sort keys %$hash) . '}';
+}
+
+sub _dumper_value {
+    my ($value) = @_;
+    return 'undef' unless defined $value;
+    return _dumper_hash($value) if ref($value) eq 'HASH';
+    if (ref($value) eq 'ARRAY') {
+	return '[' . join(',', map _dumper_value($_), @$value) . ']';
+    }
+    return _dumper_quote($value);
+}
