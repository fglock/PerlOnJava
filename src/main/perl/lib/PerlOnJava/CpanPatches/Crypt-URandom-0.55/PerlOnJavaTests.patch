--- t/core_fork.t.orig
+++ t/core_fork.t
@@ -3,5 +3,15 @@
 use strict;
 use warnings;
+BEGIN {
+    my $is_perlonjava = ($ENV{PERLONJAVA_EXECUTABLE} || $^X || '')
+        =~ m{(?:^|[\\/])jperl(?:\\.bat)?$};
+    if ($is_perlonjava) {
+        require Test::More;
+        Test::More::plan(skip_all =>
+            'PerlOnJava does not implement fork()');
+    }
+}
+
 use Test::More;
 
