--- perl5/cpan/CPAN/lib/CPAN/HandleConfig.pm
+++ src/main/perl/lib/CPAN/HandleConfig.pm
@@ -546,8 +546,11 @@
     push @dirs, $ENV{USERPROFILE} if $ENV{USERPROFILE};
 
     $CPAN::Config->{load_module_verbosity} = $old_v;
